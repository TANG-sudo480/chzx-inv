[project]
sub_id = "1d8759b2"
name = "ev-industry-chain"
requires = ["nodejs-24"]
project_type = "web"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "scripts/coze-preview-build.sh"]
run = ["bash", "scripts/coze-preview-run.sh"]

[subprojects]
path = ["."]

[deploy]
build = ["bash", "scripts/coze-deploy-build.sh"]
run = ["bash", "scripts/coze-deploy-run.sh"]

[deploy.profile]
kind = "service"
flavor = "web"
